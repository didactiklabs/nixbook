apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: 
    server: https://172.16.255.212:6443
  name: mgmt
contexts:
- context:
    cluster: mgmt
    user: -oidc
  name: oidc@mgmt
current-context: oidc@mgmt
kind: Config
users:
- name: -oidc
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      command: kubectl
      args:
      - oidc-login
      - get-token
      - --oidc-issuer-url=https://rpcu-gabeck.eu1.zitadel.cloud
      - --oidc-client-id=377050089077613929
      - --oidc-extra-scope=email
      - --oidc-extra-scope=profile
      - --oidc-extra-scope=groups
